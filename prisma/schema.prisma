generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MANAGER
  SALES
  WAREHOUSE
  DRIVER
  WHOLESALE
  CLIENT
}

enum WholesaleApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum BusinessType {
  PRODUCTION
  SHOP
  SUBDISTRIBUTOR
  MARKET_POINT
  OTHER
}

enum OrderStatus {
  PENDING
  PAID
  PACKAGING
  IN_TRANSIT
  DELIVERED
  CANCELLED
}

enum BoltsType {
  EARNED
  SPENT
}

// ========== ERP Enums ==========

enum DocumentStatus {
  DRAFT
  CONFIRMED
  PACKING
  IN_TRANSIT
  DELIVERED
  CANCELLED
}

enum DeliveryMethod {
  DRIVER
  SALES_REP_PICKUP
  SELF_PICKUP
}

enum DeliveryRouteStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum DeliveryStopStatus {
  PENDING
  LOADED
  DELIVERED
  FAILED
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
}

enum CommissionStatus {
  PENDING
  APPROVED
  PAID
}

enum CounterpartyType {
  SUPPLIER
  CUSTOMER
  BOTH
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  password     String?
  name         String
  phone        String?
  role         Role     @default(CLIENT)
  boltsBalance Float    @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  orders                Order[]
  boltsTransactions     BoltsTransaction[]
  wholesaleApplications WholesaleApplication[]

  companyId String?
  company   WholesaleCompany? @relation(fields: [companyId], references: [id])

  // ERP relations
  purchaseOrdersCreated PurchaseOrder[]    @relation("purchaseOrderCreator")
  salesDocumentsCreated SalesDocument[]    @relation("salesDocCreator")
  salesRepSales         SalesDocument[]    @relation("salesRepSales")
  invoicesCreated       Invoice[]          @relation("invoiceCreator")
  commissionRates       CommissionRate[]   @relation("commissionRates")
  commissionRecords     CommissionRecord[] @relation("commissionRecords")

  // Delivery relations
  driverRoutes  DeliveryRoute[] @relation("driverRoutes")
  createdRoutes DeliveryRoute[] @relation("routeCreator")
}

model Category {
  id       String    @id @default(cuid())
  name     String
  slug     String    @unique
  image    String?
  products Product[]
}

model Product {
  id             String   @id @default(cuid())
  sku            String?  @unique
  name           String
  slug           String   @unique
  description    String
  price          Float
  wholesalePrice Float?
  image          String?
  stock          Int      @default(0)
  isActive       Boolean  @default(true)
  priority       Int      @default(0)
  isPromo        Boolean  @default(false)
  promoPrice     Float?
  promoLabel     String?
  // Tool specification fields (optional)
  powerWatts     Int? // Потужність (Вт)
  rpm            Int? // Обороти (об/хв)
  discDiameterMm Int? // Діаметр диска (мм)
  chuckMm        Float? // Патрон (мм)
  toolType       String? // drill | grinder | saw | jigsaw | sander
  weightKg       Float? // Вага (кг)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  categoryId String
  category   Category          @relation(fields: [categoryId], references: [id])
  orderItems OrderItem[]
  embedding  ProductEmbedding?

  // ERP relations
  supplierProducts   SupplierProduct[]
  purchaseOrderItems PurchaseOrderItem[]
  salesDocumentItems SalesDocumentItem[]
  reservations       StockReservation[]
}

model SeasonalPromo {
  id          String    @id @default(cuid())
  title       String // "Весняний розпродаж", "Зимові знижки"
  description String?
  season      String // spring, summer, autumn, winter, custom
  icon        String? // emoji
  color       String    @default("#FFD600") // accent color
  keywords    String[] // product name keywords to auto-match
  categoryIds String[] // category IDs to include
  productIds  String[] // manually pinned product IDs
  isActive    Boolean   @default(true)
  startDate   DateTime? // for custom date ranges
  endDate     DateTime?
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model ImportLog {
  id        String   @id @default(cuid())
  type      String
  filename  String
  status    String
  created   Int      @default(0)
  updated   Int      @default(0)
  skipped   Int      @default(0)
  errors    Int      @default(0)
  details   String?
  createdAt DateTime @default(now())
}

model Order {
  id          String      @id @default(cuid())
  userId      String
  totalAmount Float
  boltsUsed   Float       @default(0)
  boltsEarned Float       @default(0)
  status      OrderStatus @default(PENDING)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  user  User        @relation(fields: [userId], references: [id])
  items OrderItem[]
}

model OrderItem {
  id        String @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  price     Float

  order   Order   @relation(fields: [orderId], references: [id])
  product Product @relation(fields: [productId], references: [id])
}

model BoltsTransaction {
  id          String    @id @default(cuid())
  userId      String
  amount      Float
  type        BoltsType
  orderId     String?
  description String
  createdAt   DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])
}

model ProductEmbedding {
  id          String   @id @default(cuid())
  productId   String   @unique
  embedding   String
  textContent String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model AiChatHistory {
  id        String   @id @default(cuid())
  userId    String?
  sessionId String
  role      String
  content   String
  createdAt DateTime @default(now())
}

model WholesaleCompany {
  id           String       @id @default(cuid())
  legalName    String
  phone        String
  email        String
  address      String
  businessType BusinessType
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  managers     User[]
  applications WholesaleApplication[]
}

model WholesaleBrandDiscount {
  id        String   @id @default(cuid())
  brand     String   @unique
  discount  Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WholesaleApplication {
  id           String                     @id @default(cuid())
  userId       String
  companyId    String?
  legalName    String
  contactName  String
  phone        String
  email        String
  address      String
  businessType BusinessType
  status       WholesaleApplicationStatus @default(PENDING)
  reviewedBy   String?
  reviewNote   String?
  createdAt    DateTime                   @default(now())
  updatedAt    DateTime                   @updatedAt

  user    User              @relation(fields: [userId], references: [id])
  company WholesaleCompany? @relation(fields: [companyId], references: [id])
}

// ========== ERP Models ==========

model DocumentSequence {
  id     String @id // "PO", "SD", "INV"
  prefix String // "ПН", "ПР", "ВН"
  last   Int    @default(0)
}

model Counterparty {
  id            String           @id @default(cuid())
  name          String
  code          String?          @unique
  type          CounterpartyType @default(BOTH)
  phone         String?
  email         String?
  address       String?
  contactPerson String?
  notes         String?
  isActive      Boolean          @default(true)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  purchaseOrders   PurchaseOrder[]
  salesDocuments   SalesDocument[]
  invoices         Invoice[]
  supplierProducts SupplierProduct[]
  deliveryStops    DeliveryStop[]
}

model SupplierProduct {
  id            String   @id @default(cuid())
  supplierId    String
  productId     String
  purchasePrice Float
  lastUpdated   DateTime @default(now())

  supplier Counterparty @relation(fields: [supplierId], references: [id])
  product  Product      @relation(fields: [productId], references: [id])

  @@unique([supplierId, productId])
}

model PurchaseOrder {
  id          String         @id @default(cuid())
  number      String         @unique
  supplierId  String
  status      DocumentStatus @default(DRAFT)
  totalAmount Float          @default(0)
  notes       String?
  confirmedAt DateTime?
  createdById String
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  supplier  Counterparty        @relation(fields: [supplierId], references: [id])
  createdBy User                @relation("purchaseOrderCreator", fields: [createdById], references: [id])
  items     PurchaseOrderItem[]
}

model PurchaseOrderItem {
  id              String @id @default(cuid())
  purchaseOrderId String
  productId       String
  quantity        Int
  purchasePrice   Float

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  product       Product       @relation(fields: [productId], references: [id])
}

model SalesDocument {
  id             String         @id @default(cuid())
  number         String         @unique
  counterpartyId String?
  salesRepId     String?
  status         DocumentStatus @default(DRAFT)
  totalAmount    Float          @default(0)
  discountAmount Float          @default(0)
  profitAmount   Float          @default(0)
  notes          String?
  confirmedAt    DateTime?
  createdById    String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  deliveryMethod DeliveryMethod?
  deliveryNotes  String?

  counterparty Counterparty?       @relation(fields: [counterpartyId], references: [id])
  salesRep     User?               @relation("salesRepSales", fields: [salesRepId], references: [id])
  createdBy    User                @relation("salesDocCreator", fields: [createdById], references: [id])
  items        SalesDocumentItem[]
  invoice      Invoice?
  commissions  CommissionRecord[]
  reservations StockReservation[]
  deliveryStop DeliveryStop?
}

model SalesDocumentItem {
  id              String @id @default(cuid())
  salesDocumentId String
  productId       String
  quantity        Int
  sellingPrice    Float
  purchasePrice   Float
  discountPercent Float  @default(0)

  salesDocument SalesDocument @relation(fields: [salesDocumentId], references: [id], onDelete: Cascade)
  product       Product       @relation(fields: [productId], references: [id])
}

model Invoice {
  id              String         @id @default(cuid())
  number          String         @unique
  salesDocumentId String?        @unique
  counterpartyId  String
  status          DocumentStatus @default(DRAFT)
  paymentStatus   PaymentStatus  @default(UNPAID)
  totalAmount     Float
  paidAmount      Float          @default(0)
  dueDate         DateTime?
  notes           String?
  createdById     String
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  salesDocument SalesDocument? @relation(fields: [salesDocumentId], references: [id])
  counterparty  Counterparty   @relation(fields: [counterpartyId], references: [id])
  createdBy     User           @relation("invoiceCreator", fields: [createdById], references: [id])
  payments      Payment[]
}

model Payment {
  id        String   @id @default(cuid())
  invoiceId String
  amount    Float
  method    String   @default("bank_transfer")
  notes     String?
  createdAt DateTime @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id])
}

model CommissionRate {
  id         String @id @default(cuid())
  salesRepId String
  brand      String
  percentage Float

  salesRep User @relation("commissionRates", fields: [salesRepId], references: [id])

  @@unique([salesRepId, brand])
}

model CommissionRecord {
  id               String           @id @default(cuid())
  salesRepId       String
  salesDocumentId  String
  brand            String
  saleAmount       Float
  costAmount       Float
  profitAmount     Float
  commissionRate   Float
  commissionAmount Float
  status           CommissionStatus @default(PENDING)
  paidAt           DateTime?
  createdAt        DateTime         @default(now())

  salesRep      User          @relation("commissionRecords", fields: [salesRepId], references: [id])
  salesDocument SalesDocument @relation(fields: [salesDocumentId], references: [id])
}

// ========== Stock Reservation ==========

model StockReservation {
  id              String   @id @default(cuid())
  productId       String
  salesDocumentId String
  quantity        Int
  createdAt       DateTime @default(now())

  product       Product       @relation(fields: [productId], references: [id])
  salesDocument SalesDocument @relation(fields: [salesDocumentId], references: [id], onDelete: Cascade)

  @@unique([productId, salesDocumentId])
}

// ========== Delivery / Logistics ==========

model DeliveryRoute {
  id              String              @id @default(cuid())
  number          String              @unique
  driverId        String?
  date            DateTime
  status          DeliveryRouteStatus @default(PLANNED)
  vehicleInfo     String?
  fuelConsumption Float? // л/100км або кВт·год/100км
  fuelPricePer    Float? // ціна за 1л або 1кВт·год
  totalDistanceKm Float?
  totalFuelCost   Float?
  notes           String?
  createdById     String
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  driver    User?          @relation("driverRoutes", fields: [driverId], references: [id])
  createdBy User           @relation("routeCreator", fields: [createdById], references: [id])
  stops     DeliveryStop[]
}

model DeliveryStop {
  id              String             @id @default(cuid())
  deliveryRouteId String
  salesDocumentId String             @unique
  counterpartyId  String?
  sequence        Int                @default(0)
  distanceKm      Float?
  deliveryCost    Float?
  status          DeliveryStopStatus @default(PENDING)
  address         String?
  notes           String?
  deliveredAt     DateTime?
  createdAt       DateTime           @default(now())

  deliveryRoute DeliveryRoute @relation(fields: [deliveryRouteId], references: [id], onDelete: Cascade)
  salesDocument SalesDocument @relation(fields: [salesDocumentId], references: [id])
  counterparty  Counterparty? @relation(fields: [counterpartyId], references: [id])
}
